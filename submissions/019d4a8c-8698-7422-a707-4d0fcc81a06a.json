{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "challenger_api_key": {
        "type": "string"
      }
    },
    "required": [
      "challenger_api_key"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.1/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "games": 10,
          "max_rounds": 5,
          "discount": 0.98,
          "bootstrap": 100,
          "full_matrix": true
        },
        "participant_roles": {
          "green": "green",
          "purple1": "challenger"
        },
        "callback_urls": {
          "green": "${bindings.green-proxy.url}"
        }
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/MAizeBargAIn-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {}
    },
    "challenger": {
      "manifest": "https://raw.githubusercontent.com/Necentt/bonus_track_hw/main/amber-manifest.json5",
      "config": {
        "api_key": "${config.challenger_api_key}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#challenger.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "green-proxy"
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019cfd96-75cb-7873-80ee-60683ace10be",
      "challenger": "019d4a74-2fcd-7843-8b2d-eaaa6a2914c0"
    }
  }
}