{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "challenger_agent_llm": {
        "type": "string"
      },
      "challenger_deepseek_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      },
      "challenger_gemini_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      },
      "challenger_openai_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      },
      "challenger_openai_base_url": {
        "type": "string",
        "default": "https://openrouter.ai/api/v1"
      },
      "challenger_openai_timeout": {
        "type": "string",
        "default": "45"
      }
    },
    "required": [
      "challenger_agent_llm"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.1/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "games": 10,
          "max_rounds": 5,
          "discount": 0.98,
          "bootstrap": 100,
          "full_matrix": true
        },
        "participant_roles": {
          "green": "green",
          "purple1": "challenger"
        },
        "callback_urls": {
          "green": "${bindings.green-proxy.url}",
          "purple1": "${bindings.purple1-proxy.url}"
        }
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/MAizeBargAIn-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {}
    },
    "challenger": {
      "manifest": "https://raw.githubusercontent.com/SPI315/Purple_Agent/main/amber-manifest.json5",
      "config": {
        "agent_llm": "${config.challenger_agent_llm}",
        "deepseek_api_key": "${config.challenger_deepseek_api_key}",
        "gemini_api_key": "${config.challenger_gemini_api_key}",
        "openai_api_key": "${config.challenger_openai_api_key}",
        "openai_base_url": "${config.challenger_openai_base_url}",
        "openai_timeout": "${config.challenger_openai_timeout}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#challenger.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "green-proxy"
    },
    {
      "to": "#challenger.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "purple1-proxy"
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019cfd96-75cb-7873-80ee-60683ace10be",
      "challenger": "019d59c7-721f-7651-bea3-9aa3f7dca03d"
    }
  }
}